<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Apple HIG Typography Scale (macOS sizes, Inter font) -->
  <!-- Font family set globally via WithInterFont() in Program.cs -->

  <!-- ═══════════ Type Styles ═══════════ -->

  <x:Double x:Key="FontSizeLargeTitle">26</x:Double>
  <x:Double x:Key="FontSizeTitle1">22</x:Double>
  <x:Double x:Key="FontSizeTitle2">17</x:Double>
  <x:Double x:Key="FontSizeTitle3">15</x:Double>
  <x:Double x:Key="FontSizeHeadline">13</x:Double>
  <x:Double x:Key="FontSizeBody">13</x:Double>
  <x:Double x:Key="FontSizeCallout">12</x:Double>
  <x:Double x:Key="FontSizeSubheadline">11</x:Double>
  <x:Double x:Key="FontSizeFootnote">10</x:Double>
  <x:Double x:Key="FontSizeCaption1">10</x:Double>
  <x:Double x:Key="FontSizeCaption2">10</x:Double>

  <!-- ═══════════ Spacing Scale (8pt grid) ═══════════ -->

  <x:Double x:Key="Space1">4</x:Double>
  <x:Double x:Key="Space2">8</x:Double>
  <x:Double x:Key="Space3">12</x:Double>
  <x:Double x:Key="Space4">16</x:Double>
  <x:Double x:Key="Space5">20</x:Double>
  <x:Double x:Key="Space6">24</x:Double>
  <x:Double x:Key="Space8">32</x:Double>
  <x:Double x:Key="Space10">40</x:Double>

  <!-- ═══════════ Corner Radii ═══════════ -->

  <CornerRadius x:Key="RadiusXs">4</CornerRadius>
  <CornerRadius x:Key="RadiusSm">6</CornerRadius>
  <CornerRadius x:Key="RadiusMd">8</CornerRadius>
  <CornerRadius x:Key="RadiusLg">10</CornerRadius>
  <CornerRadius x:Key="RadiusXl">12</CornerRadius>

  <!-- ═══════════ Component Heights ═══════════ -->

  <x:Double x:Key="ToolbarHeight">48</x:Double>
  <x:Double x:Key="StatusBarHeight">28</x:Double>
  <x:Double x:Key="SidebarWidth">220</x:Double>
  <x:Double x:Key="PropertiesPanelWidth">260</x:Double>
  <x:Double x:Key="ButtonHeight">28</x:Double>
  <x:Double x:Key="TextFieldHeight">28</x:Double>
  <x:Double x:Key="SidebarRowHeight">30</x:Double>

</ResourceDictionary>
